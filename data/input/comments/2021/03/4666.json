    "author_association": "CONTRIBUTOR",
    "body": "I think this should follow your use case: https://codesandbox.io/s/amazing-ganguly-69jxx?file=/src/app.js\r\n\r\n1. loop to add all widgets\r\n2. conditionally do css in a custom widget's `render` function\r\n\r\n```js\r\nconst toggles = [\r\n  { attribute: 'brand', value: 'Apple' },\r\n  { attribute: 'brand', value: 'Samsung' },\r\n  { attribute: 'brand', value: 'Samsung' },\r\n  { attribute: 'brand', value: 'Samsung' },\r\n];\r\n\r\nfunction superPanel({ container, values }) {\r\n  const containerNode = document.querySelector(container);\r\n  return [\r\n    ...values.map(({ attribute, value }) => {\r\n      const toggleContainer = document.createElement('div');\r\n      containerNode.appendChild(toggleContainer);\r\n\r\n      return instantsearch.widgets.toggleRefinement({\r\n        container: toggleContainer,\r\n        attribute,\r\n        templates: {\r\n          labelText: `${value} {{count}}`,\r\n        },\r\n        on: value,\r\n      });\r\n    }),\r\n    {\r\n      init() {},\r\n      render({ results }) {\r\n        const facetValues = values.map(({ attribute, value }) => {\r\n          const allValues = results.getFacetValues(attribute);\r\n          return allValues.find(({ name }) => name === value) || {};\r\n        });\r\n\r\n        const shouldShow = facetValues.some(({ count }) => count > 0);\r\n\r\n        containerNode.style.opacity = shouldShow ? 1 : 0.5;\r\n        // alternative style:\r\n        // containerNode.hidden = !shouldShow;\r\n      },\r\n    },\r\n  ];\r\n}\r\n\r\nsearch.addWidgets(superPanel({container: \".search-panel__filters\", values}))\r\n```",
