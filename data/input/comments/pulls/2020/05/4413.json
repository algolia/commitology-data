  {
    "author_association": "CONTRIBUTOR",
    "body": "I think @francoischalifour was thinking about an integration test closer to the real usage from a user POV.\r\n\r\nHere's an example using testing-libary: \r\n\r\n```js\r\nimport { wait, getByLabelText } from '@testing-library/dom';\r\n\r\nimport instantsearch from '../../../';\r\n\r\nimport apiResults from './__fixtures__/api-results.json';\r\n\r\ndescribe('infiniteHits', () => {\r\n  let search;\r\n  let searchClient;\r\n\r\n  beforeEach(() => {\r\n    searchClient = {\r\n      search: jest.fn(() => Promise.resolve(apiResults)),\r\n    };\r\n\r\n    search = instantsearch({\r\n      indexName: 'instant_search',\r\n      searchClient,\r\n    });\r\n  });\r\n\r\n  afterEach(() => {\r\n    try {\r\n      search.dispose();\r\n    } catch (e) {\r\n      // Fail if the search was never started, ignoring\r\n    }\r\n  });\r\n\r\n  it('must hit cache when navigating to a previously visited page', async () => {\r\n    const infiniteHitsContainer = document.createElement('div');\r\n    const paginationContainer = document.createElement('div');\r\n\r\n    const customCache = {\r\n      read: jest.fn(() => {\r\n        // Your custom read implementation\r\n      }),\r\n      write: jest.fn(() => {\r\n        // Your custom write implementation\r\n      }),\r\n    };\r\n\r\n    search.addWidgets([\r\n      instantsearch.widgets.infiniteHits({\r\n        container: infiniteHitsContainer,\r\n        cache: customCache,\r\n      }),\r\n      instantsearch.widgets.pagination({\r\n        container: paginationContainer,\r\n        scrollTo: false,\r\n      }),\r\n    ]);\r\n\r\n    search.start();\r\n\r\n    await wait();\r\n\r\n    // Assert that the client was called (page 1 was not cached)\r\n    expect(searchClient.search).toBeCalledTimes(1);\r\n\r\n    // Navigate to page 2\r\n    getByLabelText(paginationContainer, 'Next').click();\r\n\r\n    await wait();\r\n\r\n    // Assert that the client was called (page 2 was not cached)\r\n    expect(searchClient.search).toBeCalledTimes(2);\r\n\r\n    // Navigate to page 1\r\n    getByLabelText(paginationContainer, 'Previous').click();\r\n\r\n    await wait();\r\n\r\n    // Assert that the client was not called (page 1 was cached)\r\n    expect(searchClient.search).toBeCalledTimes(2);\r\n  });\r\n});\r\n```",
