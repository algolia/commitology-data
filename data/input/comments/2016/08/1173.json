    "author_association": "NONE",
    "body": "**instantsearch.js**\n\n``` javascript\nsearch = instantsearch({\n  appId: 'XXX',\n  apiKey: 'YYY',\n  indexName: 'instantsearch_index'\n});\nsearch.start();\n```\n\n**autocomplete.js**\n\n``` javascript\n    var client = algoliasearch('XXX', 'YYY');\n    var index = client.initIndex('autocomplete_index');\n    $('#main-search-form .form-control').autocomplete({ hint: true }, [\n        {\n          source: $.fn.autocomplete.sources.hits(index, { hitsPerPage: 10 }),\n          displayKey: 'name',\n          templates: {\n            suggestion: function(suggestion) {\n              return suggestion._highlightResult.name.value;\n            }\n          }\n        }\n    ]).on('autocomplete:selected', function(event, suggestion, dataset) {\n        search.helper.setQuery(suggestion.name).search();\n    });\n```\n",
