    "body": "SOLVED\r\n\r\ntransformData: {\r\n          item(item) {\r\n            if(item.displayOperator == '&ge ;'){ item.displayOperator = \"cena od\"; item.name += ' zł'; };\r\n            if(item.displayOperator == '&le ;'){ item.displayOperator = \"cena do\"; item.name += ' zł'; };\r\n            return item\r\n          },\r\n        },",
