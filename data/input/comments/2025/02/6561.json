    "body": "@Haroenv Thanks so much for your quick reply! Unfortunately It's still not working for me. Do I need to be using a router.js file? That's the only difference I see between your code and mine.\n ```\nconst routing = {\n        stateMapping: {\n          stateToRoute(uiState) {\n            const indexUiState = uiState['all-products'];\n            // console.log(\"indexUiState\", indexUiState)\n            return {\n                query: \n                    indexUiState.configure && \n                    indexUiState.configure.query ? indexUiState.configure.query : indexUiState.query,\n                categories: \n                    indexUiState.refinementList && \n                    indexUiState.refinementList['category.lvl0'],\n                all: indexUiState.all,\n                brand:\n                    indexUiState.refinementList &&\n                    indexUiState.refinementList.brand,\n                page: indexUiState.page,\n                manufacturing: \n                    indexUiState.refinementList &&\n                    indexUiState.refinementList._tags,\n                demographics: \n                    indexUiState.refinementList &&\n                    indexUiState.refinementList.demographics\n            };\n          },\n          routeToState(routeState) {\n            // console.log(\"routeState\", routeState)\n            let rsBrand = []\n            if (Array.isArray(routeState && routeState.brand)) {\n                routeState.brand.forEach((b) => rsBrand.push(b))\n            } else if (routeState && routeState.brand) rsBrand.push(routeState.brand)\n            return {\n                ['all-products']: {\n                    query: routeState && routeState.query,\n                    refinementList: {\n                        brand: rsBrand.length > 0 ? rsBrand : [],\n                        _tags: routeState && routeState.manufacturing ? [routeState.manufacturing] : [],\n                        ['category.lvl0']: routeState && routeState.categories ? [routeState.categories] : [],\n                        demographics: routeState && routeState.demographics ? [routeState.demographics] : []\n                    },\n                    page: routeState && routeState.page\n                },\n            };\n          },\n        },\n        router: {\n          read() {\n            return vueRouter.currentRoute.query;\n          },\n          write(routeState) {\n            vueRouter.push({\n              query: routeState,\n            });\n          },\n          createURL(routeState) {\n            return vueRouter.resolve({\n              query: routeState,\n            }).href;\n          },\n          onUpdate(cb) {\n            this._onPopState = () => {\n              cb(this.read());\n            };\n            window.addEventListener('popstate', this._onPopState);\n          },\n          dispose() {\n            window.removeEventListener('popstate', this._onPopState);\n            this.write();\n          },\n        },\n    }\n```\nI haven't seen an instance where my event.state is empty while navigating. The screenshot below shows what happens when I'm on page 5 and hit the browser back button. The console log is of `event.state` Even though it shows the new current being page 4, you can see the url updates to page 1.\n\n![Image](https://github.com/user-attachments/assets/5a8dd5b7-660b-4ddb-8b73-91a806d81286)",
