    "author_association": "NONE",
    "body": "A possible short term solution is goto https://github.com/algolia/algoliasearch-client-javascript. Here is an example of a angular 4 component using angular material autocomplete in typescript...\r\n\r\n```ts\r\nimport { Component, OnInit } from \"@angular/core\";\r\nimport { FormControl } from \"@angular/forms\";\r\n\r\n// dirty way to get require to work, only for example purposes\r\ndeclare var require: any;\r\n\r\n// import the algoria library and put in your algolia ids and keys\r\nconst algoliasearch = require(\"algoliasearch\");\r\nconst client = algoliasearch(\"appId\", \"apiKey\");\r\n\r\n@Component({\r\n  selector: \"app-op70\",\r\n  template: `\r\n  <md-input-container>\r\n    <input mdInput  [mdAutocomplete]=\"auto\" [formControl]=\"itemsCtrl\" (ngModelChange)=\"check($event)\" >\r\n  </md-input-container>\r\n  <md-autocomplete #auto=\"mdAutocomplete\">\r\n    <md-option *ngFor=\"let item of data\" [value]=\"item\" >\r\n      {{item|json}}\r\n    </md-option>\r\n  </md-autocomplete>\r\n  `,\r\n  styleUrls: [\"./op70.component.css\"]\r\n})\r\nexport class Op70Component implements OnInit {\r\n  index: any;\r\n  data: Array<string>;\r\n  itemsCtrl: FormControl;\r\n  constructor() {\r\n    // set up the reference to the index in algolia\r\n    this.index = client.initIndex(\"getstarted_actors\");\r\n\r\n    // set up the material design autocomplete\r\n    this.itemsCtrl = new FormControl();\r\n  }\r\n\r\n  ngOnInit() {}\r\n\r\n  check(val) {\r\n    // take the val from the material design input and send it to algolia and use the response\r\n    // to update the options.\r\n    this.index.search(val).then(res => {\r\n      this.data = res.hits;\r\n    });\r\n  }\r\n}\r\n```",
