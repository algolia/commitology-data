    "author_association": "NONE",
    "body": "**Implementation example:** \r\n```javascript\r\nconst SearchBox = connectSearchBox(({refine}) => {\r\n  const [readValue, writeValue] = useState(emptyStr)\r\n  const handleChange = ({currentTarget: {value}}: EventInput) => writeValue(value)\r\n  const handleSubmit = () => readValue !== emptyStr && refine(readValue)\r\n  const handleClear = () => {\r\n    writeValue(emptyStr)\r\n    refine(emptyStr)\r\n  }\r\n  return (\r\n    <>\r\n      <label htmlFor='search-input'>Search</label>\r\n      <input id='search-input' type='search' value={readValue} onChange={handleChange} />\r\n      <button onClick={handleSubmit}>Search</button>\r\n      <button onClick={handleClear}>Clear</button>\r\n    </>\r\n```",
