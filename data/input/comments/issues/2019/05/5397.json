    "author_association": "NONE",
    "body": "In addition to not setting the correct value, I've found that the router only updates for changes to the value set at page first load. \r\nE.g. Page loads at `/search?hitsPerPage=20`, when you select 10 the url changes to `/search?hitsPerPage=10`, when you select 20 again the url changes to `/search`.",
    "created_at": "2019-07-23T15:08:57Z",
    "html_url": "https://github.com/algolia/instantsearch/issues/5397#issuecomment-1367968930",
    "id": 1367968930,
    "issue_url": "https://api.github.com/repos/algolia/instantsearch/issues/5397",
    "node_id": "MDEyOklzc3VlQ29tbWVudDEzNjc5Njg5MzA=",
    "performed_via_github_app": null,
    "pin": null,
