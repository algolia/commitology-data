    "author_association": "NONE",
    "body": "Be aware that this is a bug in Chrome and probably Safari when SVG2 is landing.\r\nSee the discussion in https://bugzilla.mozilla.org/show_bug.cgi?id=1433360#c2 with spec reference.\r\nTo fix the issue it is necessary to put the width on the use element.",
    "created_at": "2018-01-26T13:16:22Z",
    "html_url": "https://github.com/algolia/instantsearch/issues/2536#issuecomment-360781747",
    "id": 360781747,
    "issue_url": "https://api.github.com/repos/algolia/instantsearch/issues/2536",
    "node_id": "MDEyOklzc3VlQ29tbWVudDM2MDc4MTc0Nw==",
    "performed_via_github_app": null,
    "pin": null,
