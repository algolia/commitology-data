    "body": "Implementation of the check which probably could work:\r\n\r\n```js\r\nif (__DEV__) {\r\n  // defined in index widget\r\n  function isIndexWidget(widget: Widget): widget is Index {\r\n    return widget.$$type === 'ais.index';\r\n  }\r\n\r\n  // pretty much the same as resolveScopedResultsFromWidgets\r\n  function getIndexIds(widgets: Widget[]): string[] {\r\n    const indexWidgets = widgets.filter(isIndexWidget);\r\n  \r\n    return indexWidgets.reduce<string[]>((scopedResults, current) => {\r\n      return scopedResults.concat(\r\n        current.getIndexId(),\r\n        ...getIndexIds(current.getWidgets())\r\n      );\r\n    }, []);\r\n  }\r\n\r\n  const indexIds = Object.keys(initialUiState);\r\n  const expectedIndexIds = getIndexIds(mainIndex.getWidgets());\r\n\r\n  if (indexIds.every(id => expectedIndexIds.indexOf(id) === -1)) {\r\n    console.log('warning')\r\n  }\r\n}\r\n```",
